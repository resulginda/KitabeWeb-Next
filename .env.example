# ============================================================
# KitabeWeb-Next — Dokploy Environment Variables
# Dokploy panelinde "Environment" bölümüne TEK TEK ekleyin.
# ============================================================

# Zorunlu — Backend API
NEXT_PUBLIC_API_URL=https://api.kitabe.org

# Zorunlu — Canonical URL (SEO, sitemap, hreflang)
NEXT_PUBLIC_SITE_URL=https://kitabe.org

# Zorunlu — Admin güncellemesinde ISR tetikleme (backend ile AYNI olmalı)
REVALIDATE_SECRET=buraya-guclu-rastgele-bir-secret-yazin-ornek-K7mP9xQ2vL4nR8wT

# Opsiyonel — Sunucu tarafı API fetch (boşsa REVALIDATE_SECRET kullanılır)
# SERVER_API_KEY=

# Opsiyonel — AdSense (DetailPage reklamları)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-2826589713246354

# Dokploy genelde PORT'u otomatik verir; yoksa:
PORT=3000
NODE_ENV=production

# ============================================================
# Ayrıca api.kitabe.org backend .env dosyasına da ekleyin:
# REVALIDATE_SECRET=aynı-secret-yukarıdakiyle-birebir
# NEXT_SITE_URL=https://kitabe.org
# ============================================================
